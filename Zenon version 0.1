-- ==================== СИСТЕМА ПЕРЕТАСКИВАНИЯ ====================
local dragObject = nil
local dragStart = nil
local startPos = nil
local dragging = false

local function makeDraggable(frame, handle)
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragObject = frame
            dragStart = input.Position
            startPos = frame.Position
            dragging = true
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragObject = nil
                    dragging = false
                end
            end)
        end
    end)
    
    handle.InputChanged:Connect(function(input)
        if dragObject == frame and (input.UserInputType == Enum.UserInputType.MouseMovement or 
                                     input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            local newPos = UDim2.new(
                startPos.X.Scale, 
                startPos.X.Offset + delta.X,
                startPos.Y.Scale, 
                startPos.Y.Offset + delta.Y
            )
            
            local screenSize = workspace.CurrentCamera.ViewportSize
            local frameSize = frame.AbsoluteSize
            
            newPos = UDim2.new(
                newPos.X.Scale,
                math.clamp(newPos.X.Offset, -frameSize.X + 50, screenSize.X - 50),
                newPos.Y.Scale,
                math.clamp(newPos.Y.Offset, 0, screenSize.Y - 50)
            )
            
            frame.Position = newPos
        end
    end)
end

