local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera

-- Хранилище ESP объектов
local Drawings = {}

-- Очистка ESP
function CleanupESP()
    for _, drawings in pairs(Drawings) do
        for _, drawing in pairs(drawings) do
            pcall(function() drawing:Remove() end)
        end
    end
    Drawings = {}
end

-- Создание ESP для игрока
function CreateESP(player)
    local drawings = {}
    
    if espConfig.showBoxes then
        local box = Drawing.new("Square")
        box.Visible = false
        box.Color = espConfig.boxColor
        box.Thickness = espConfig.boxThickness
        box.Filled = false
        box.Transparency = 1
        drawings.Box = box
    end
    
    if espConfig.showTracers then
        local tracer = Drawing.new("Line")
        tracer.Visible = false
        tracer.Color = espConfig.tracerColor
        tracer.Thickness = 1
        tracer.Transparency = 1
        drawings.Tracer = tracer
    end
    
    if espConfig.showNames then
        local nameText = Drawing.new("Text")
        nameText.Visible = false
        nameText.Color = espConfig.nameColor
        nameText.Size = 13
        nameText.Center = true
        nameText.Outline = true
        nameText.Font = 2
        drawings.Name = nameText
    end
    
    if espConfig.showDistance then
        local distText = Drawing.new("Text")
        distText.Visible = false
        distText.Color = espConfig.nameColor
        distText.Size = 13
        distText.Center = true
        distText.Outline = true
        distText.Font = 2
        drawings.Distance = distText
    end
    
    Drawings[player] = drawings
    return drawings
end

-- Обновление ESP
function UpdateESP()
    if not espConfig.enabled then 
        for _, drawings in pairs(Drawings) do
            for _, drawing in pairs(drawings) do
                drawing.Visible = false
            end
        end
        return 
    end
    
    for player, drawings in pairs(Drawings) do
        if player ~= LocalPlayer and player.Character then
            local character = player.Character
            local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            local head = character:FindFirstChild("Head")
            
            if humanoidRootPart and humanoid and head and humanoid.Health > 0 then
                local screenPos, onScreen = Camera:WorldToScreenPoint(humanoidRootPart.Position)
                
                if onScreen then
                    local distance = (Camera.CFrame.Position - humanoidRootPart.Position).Magnitude
                    local scale = math.clamp(10 / distance, 0.5, 1.5)
                    
                    local headPos = Camera:WorldToScreenPoint(head.Position + Vector3.new(0, 0.5, 0))
                    local legPos = Camera:WorldToScreenPoint(humanoidRootPart.Position - Vector3.new(0, 3, 0))
                    
                    local boxHeight = math.abs(headPos.Y - legPos.Y)
                    local boxWidth = boxHeight * 0.65
                    
                    -- Box
                    if drawings.Box then
                        drawings.Box.Visible = true
                        drawings.Box.Color = espConfig.boxColor
                        drawings.Box.Thickness = espConfig.boxThickness
                        drawings.Box.Position = Vector2.new(screenPos.X - boxWidth/2, screenPos.Y - boxHeight/2)
                        drawings.Box.Size = Vector2.new(boxWidth, boxHeight)
                    end
                    
                    -- Tracer
                    if drawings.Tracer then
                        drawings.Tracer.Visible = true
                        drawings.Tracer.Color = espConfig.tracerColor
                        drawings.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                        drawings.Tracer.To = Vector2.new(screenPos.X, screenPos.Y)
                    end
                    
                    -- Name
                    if drawings.Name then
                        drawings.Name.Visible = true
                        drawings.Name.Color = espConfig.nameColor
                        drawings.Name.Text = player.Name
                        drawings.Name.Position = Vector2.new(screenPos.X, screenPos.Y - boxHeight/2 - 15)
                    end
                    
                    -- Distance
                    if drawings.Distance then
                        drawings.Distance.Visible = true
                        drawings.Distance.Color = espConfig.nameColor
                        drawings.Distance.Text = string.format("[%.0f studs]", distance)
                        drawings.Distance.Position = Vector2.new(screenPos.X, screenPos.Y + boxHeight/2 + 5)
                    end
                else
                    if drawings.Box then drawings.Box.Visible = false end
                    if drawings.Tracer then drawings.Tracer.Visible = false end
                    if drawings.Name then drawings.Name.Visible = false end
                    if drawings.Distance then drawings.Distance.Visible = false end
                end
            else
                if drawings.Box then drawings.Box.Visible = false end
                if drawings.Tracer then drawings.Tracer.Visible = false end
                if drawings.Name then drawings.Name.Visible = false end
                if drawings.Distance then drawings.Distance.Visible = false end
            end
        end
    end
end

-- Инициализация ESP для существующих игроков
for _, player in pairs(Players:GetPlayers()) do
    if player ~= LocalPlayer then
        CreateESP(player)
    end
end

-- Новые игроки
Players.PlayerAdded:Connect(function(player)
    if player ~= LocalPlayer then
        CreateESP(player)
    end
end)

-- Удаление игроков
Players.PlayerRemoving:Connect(function(player)
    if Drawings[player] then
        for _, drawing in pairs(Drawings[player]) do
            pcall(function() drawing:Remove() end)
        end
        Drawings[player] = nil
    end
end)

-- Главный цикл обновления
RunService.RenderStepped:Connect(UpdateESP)

-- Привязка очистки к закрытию GUI
local oldDestroy = ZenonGUI.Destroy
ZenonGUI.Destroy = function(...)
    CleanupESP()
    return oldDestroy(...)
end

print("Часть 2 загружена: ESP система активна")
