local Camera = workspace.CurrentCamera
local Drawings = {}
local aimTarget = nil

-- ESP
function CleanupESP()
    for _, d in pairs(Drawings) do for _, dr in pairs(d) do pcall(function() dr:Remove() end) end end
    Drawings = {}
end

function CreateESP(plr)
    local d = {}
    if espConfig.showBoxes then
        local box = Drawing.new("Square")
        box.Visible = false
        box.Color = espConfig.boxColor
        box.Thickness = espConfig.boxThickness
        box.Filled = false
        box.Transparency = 1
        d.Box = box
    end
    if espConfig.showTracers then
        local tr = Drawing.new("Line")
        tr.Visible = false
        tr.Color = espConfig.tracerColor
        tr.Thickness = 1
        tr.Transparency = 1
        d.Tracer = tr
    end
    if espConfig.showNames then
        local nm = Drawing.new("Text")
        nm.Visible = false
        nm.Color = espConfig.nameColor
        nm.Size = 13
        nm.Center = true
        nm.Outline = true
        nm.Font = 2
        d.Name = nm
    end
    if espConfig.showDistance then
        local dst = Drawing.new("Text")
        dst.Visible = false
        dst.Color = espConfig.nameColor
        dst.Size = 13
        dst.Center = true
        dst.Outline = true
        dst.Font = 2
        d.Distance = dst
    end
    Drawings[plr] = d
    return d
end

function UpdateESP()
    if not espConfig.enabled then
        for _, d in pairs(Drawings) do for _, dr in pairs(d) do dr.Visible = false end end
        return
    end
    for plr, d in pairs(Drawings) do
        if plr ~= LocalPlayer and plr.Character then
            local chr = plr.Character
            local hrp = chr:FindFirstChild("HumanoidRootPart")
            local hum = chr:FindFirstChildOfClass("Humanoid")
            local hd = chr:FindFirstChild("Head")
            if hrp and hum and hd and hum.Health > 0 then
                local sp, on = Camera:WorldToScreenPoint(hrp.Position)
                if on then
                    local dist = (Camera.CFrame.Position - hrp.Position).Magnitude
                    local hp = Camera:WorldToScreenPoint(hd.Position + Vector3.new(0,0.5,0))
                    local lp = Camera:WorldToScreenPoint(hrp.Position - Vector3.new(0,3,0))
                    local bh = math.abs(hp.Y - lp.Y)
                    local bw = bh * 0.65
                    if d.Box then
                        d.Box.Visible = true
                        d.Box.Color = espConfig.boxColor
                        d.Box.Thickness = espConfig.boxThickness
                        d.Box.Position = Vector2.new(sp.X - bw/2, sp.Y - bh/2)
                        d.Box.Size = Vector2.new(bw, bh)
                    end
                    if d.Tracer then
                        d.Tracer.Visible = true
                        d.Tracer.Color = espConfig.tracerColor
                        d.Tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                        d.Tracer.To = Vector2.new(sp.X, sp.Y)
                    end
                    if d.Name then
                        d.Name.Visible = true
                        d.Name.Color = espConfig.nameColor
                        d.Name.Text = plr.Name
                        d.Name.Position = Vector2.new(sp.X, sp.Y - bh/2 - 15)
                    end
                    if d.Distance then
                        d.Distance.Visible = true
                        d.Distance.Color = espConfig.nameColor
                        d.Distance.Text = string.format("[%.0f]", dist)
                        d.Distance.Position = Vector2.new(sp.X, sp.Y + bh/2 + 5)
                    end
                else
                    if d.Box then d.Box.Visible = false end
                    if d.Tracer then d.Tracer.Visible = false end
                    if d.Name then d.Name.Visible = false end
                    if d.Distance then d.Distance.Visible = false end
                end
            else
                if d.Box then d.Box.Visible = false end
                if d.Tracer then d.Tracer.Visible = false end
                if d.Name then d.Name.Visible = false end
                if d.Distance then d.Distance.Visible = false end
            end
        end
    end
end

-- AimBot
local function IsVisible(part)
    local rp = RaycastParams.new()
    rp.FilterDescendantsInstances = {LocalPlayer.Character}
    rp.FilterType = Enum.RaycastFilterType.Blacklist
    local ray = workspace:Raycast(Camera.CFrame.Position, (part.Position - Camera.CFrame.Position).Unit * 1000, rp)
    if ray then
        local hp = Players:GetPlayerFromCharacter(ray.Instance.Parent)
        return hp and hp ~= LocalPlayer
    end
    return false
end

local function GetClosest()
    local closest = nil
    local shortest = aimConfig.fovRadius
    local mouse = UserInputService:GetMouseLocation()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            if aimConfig.teamCheck and plr.Team == LocalPlayer.Team then continue end
            local chr = plr.Character
            if chr then
                local part = chr:FindFirstChild(aimConfig.aimPart) or chr:FindFirstChild("Head")
                if part then
                    local sp, on = Camera:WorldToScreenPoint(part.Position)
                    if on then
                        if aimConfig.visibilityCheck and not IsVisible(part) then continue end
                        local dist = (Vector2.new(sp.X, sp.Y) - mouse).Magnitude
                        if dist < shortest then
                            shortest = dist
                            closest = plr
                        end
                    end
                end
            end
        end
    end
    return closest
end

local function AimAt(target)
    local chr = target.Character
    if not chr then return end
    local part = chr:FindFirstChild(aimConfig.aimPart) or chr:FindFirstChild("Head")
    if not part then return end
    local dir = (part.Position - Camera.CFrame.Position).Unit
    if aimConfig.smoothing > 1 then
        local cur = Camera.CFrame.LookVector
        local smooth = cur:Lerp(dir, 1 / aimConfig.smoothing)
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, Camera.CFrame.Position + smooth)
    else
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, Camera.CFrame.Position + dir)
    end
end

local function UpdateAim()
    if not aimConfig.enabled then aimTarget = nil; return end
    if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local t = GetClosest()
        if t then aimTarget = t; AimAt(t) end
    else
        aimTarget = nil
    end
end

-- Init
for _, p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then CreateESP(p) end end
Players.PlayerAdded:Connect(function(p) if p ~= LocalPlayer then CreateESP(p) end end)
Players.PlayerRemoving:Connect(function(p)
    if Drawings[p] then for _, d in pairs(Drawings[p]) do pcall(function() d:Remove() end) end; Drawings[p] = nil end
    if aimTarget == p then aimTarget = nil end
end)

RunService.RenderStepped:Connect(function() UpdateESP() UpdateAim() end)

local old = ZenonGUI.Destroy
ZenonGUI.Destroy = function(...) CleanupESP() aimTarget = nil; return old(...) end

